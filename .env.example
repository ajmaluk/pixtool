# ========================================
# PixTool Environment Configuration
# Copy to .env.local and update values
# ========================================

# Site Configuration (REQUIRED)
VITE_SITE_URL=https://www.pixtool.in

# Supabase Configuration (optional - for database/auth)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Text Processing API (optional - for AI features)
VITE_TEXT_API_URL=your_api_url_with_pk

# API Timeouts (ms - optional, defaults in app.config.js)
VITE_API_TIMEOUT=12000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_SERVICE_WORKER=false

# Build Mode (automatically set by Vite)
# MODE=development
