# ===============================
# 🔁 REWRITE (SPA SUPPORT)
# ===============================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow real files and folders
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Redirect everything else to index.html
  RewriteRule . /index.html [L]
</IfModule>


# ===============================
# 🌍 SEO - INDEXING
# ===============================
<IfModule mod_headers.c>
  Header set X-Robots-Tag "index, follow"
</IfModule>


# ===============================
# ⚡ COMPRESSION (FASTER LOAD)
# ===============================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml
</IfModule>


# ===============================
# 📦 BROWSER CACHING
# ===============================
<IfModule mod_expires.c>
  ExpiresActive On

  # Images (long cache)
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"

  # CSS & JS
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"

  # HTML (short cache)
  ExpiresByType text/html "access plus 5 minutes"
</IfModule>


# ===============================
# 🔐 SECURITY HEADERS
# ===============================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>


# ===============================
# 🚫 HOTLINK PROTECTION (OPTIONAL)
# ===============================
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https://(www\.)?pixtool\.in [NC]
  RewriteRule \.(jpg|jpeg|png|webp|gif)$ - [F,NC]
</IfModule>


# ===============================
# 📄 FORCE HTTPS (IMPORTANT SEO)
# ===============================
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>