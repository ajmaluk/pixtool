{
  "name": "pixtool",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "vite build",
    "prerender": "node scripts/prerender.js",
    "validate": "node scripts/validate-build.js",
    "deploy": "npm run build && npm run validate",
    "check:bundle": "node scripts/check-bundle-size.js",
    "check-live": "node scripts/check-deployment.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "screenshots": "node scripts/generate-screenshots.js",
    "postbuild": "[ -z \"$SKIP_PRERENDER\" ] && [ -z \"$CF_PAGES\" ] && [ -z \"$NETLIFY\" ] && node scripts/prerender.js || echo \"Skipping prerender (CI/Environment check)\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "framer-motion": "^12.34.3",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.575.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "puppeteer": "^24.40.0",
    "vite": "^7.3.1"
  }
}
